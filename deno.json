{
  "nodeModulesDir": "manual",
  "tasks": {
    "check": "deno fmt --check . && deno lint . && deno check",
    "dev": "vite",
    "build": "vite build",
    "start": "deno serve --port=3004 --env-file -A _fresh/server.js",
    "update": "deno run -A -r jsr:@fresh/update .",
    "elo:recalc": "deno run -A --env-file scripts/RecalcElo.ts",
    "db:generate": "deno run -A npm:drizzle-kit generate",
    "db:migrate": "deno run -A --node-modules-dir --env-file npm:drizzle-kit migrate"
  },
  "lint": { "rules": { "tags": ["fresh", "recommended"] } },
  "exclude": ["**/_fresh/*"],
  "imports": {
    "@/": "./",
    "@libsql/client": "npm:@libsql/client@^0.17.2",
    "@std/csv": "jsr:@std/csv@^1.0.6",
    "@std/datetime": "jsr:@std/datetime@^0.225.7",
    "@std/uuid": "jsr:@std/uuid@^1.1.0",
    "@zip-js/zip-js": "jsr:@zip-js/zip-js@^2.8.26",
    "drizzle-kit": "npm:drizzle-kit@^0.31.10",
    "drizzle-orm": "npm:drizzle-orm@^0.45.2",
    "fresh": "jsr:@fresh/core@^2.3.3",
    "preact": "npm:preact@^10.29.1",
    "@preact/signals": "npm:@preact/signals@^2.9.0",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.0.8",
    "sweetalert2": "npm:sweetalert2@^11.26.24",
    "vite": "npm:vite@^7.1.3",
    "tailwindcss": "npm:tailwindcss@^4.1.10",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.1.12"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.asynciterable", "dom.iterable", "deno.ns"],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": ["vite/client"]
  },
  "allowScripts": {
    "allow": [],
    "deny": [
      "npm:better-sqlite3@12.9.0",
      "npm:esbuild@0.18.20",
      "npm:esbuild@0.25.12",
      "npm:esbuild@0.25.7",
      "npm:esbuild@0.27.7"
    ]
  }
}
